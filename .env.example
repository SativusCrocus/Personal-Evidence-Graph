# Personal Evidence Graph — environment configuration
# Copy to .env and adjust. Never commit .env.

# --- Storage roots -----------------------------------------------------------
# All file I/O is constrained to these allowlisted roots (path traversal guard).
EVG_DATA_DIR=./data
EVG_UPLOAD_DIR=./data/uploads
EVG_CHROMA_DIR=./data/chroma
EVG_SQLITE_PATH=./data/evidence.db

# Comma-separated list of folders the user has authorized for /ingest/folder
# and the watchdog. Absolute paths only.
EVG_WATCHED_ROOTS=

# --- Models ------------------------------------------------------------------
EVG_OLLAMA_HOST=http://localhost:11434
EVG_LLM_MODEL=llama3.1:8b
EVG_LLM_FALLBACK_MODEL=gemma2:2b
EVG_EMBED_MODEL=BAAI/bge-small-en-v1.5
EVG_WHISPER_BIN=whisper
EVG_WHISPER_MODEL=base.en
EVG_TESSERACT_BIN=tesseract

# --- HTTP / CORS -------------------------------------------------------------
EVG_CORS_ORIGINS=http://localhost:3000
EVG_HOST=127.0.0.1
EVG_PORT=8000

# --- Limits ------------------------------------------------------------------
EVG_MAX_UPLOAD_MB=100
EVG_RATE_LIMIT_QUERY=30/minute
EVG_RATE_LIMIT_INGEST=60/minute
EVG_RETRIEVAL_K=8
EVG_RETRIEVAL_MIN_SCORE=0.35

# --- Reranker (second-stage cross-encoder) -----------------------------------
# Adds 100-500ms per query for much better top-k ordering. Falls back silently
# to first-stage RRF order if the model can't load. Set to false to disable.
EVG_RERANKER_ENABLED=true
EVG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
EVG_RERANKER_POOL=20

# --- Claim engine (extraction + obligation + contradiction) ------------------
# Each runs after ingestion finishes. Silent skip if Ollama is unreachable.
EVG_EXTRACT_CLAIMS_DURING_INGEST=true
EVG_EXTRACT_OBLIGATIONS_DURING_INGEST=true
EVG_DETECT_CONTRADICTIONS_DURING_INGEST=true

# --- Performance -------------------------------------------------------------
EVG_CHUNK_TOKENS=512
EVG_CHUNK_OVERLAP=64
EVG_LOW_RAM_MODE=false

# --- Logging -----------------------------------------------------------------
EVG_LOG_LEVEL=INFO
